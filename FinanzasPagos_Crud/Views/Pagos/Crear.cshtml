@model FinanzasPagos_Crud.Models.Pago
@{
    ViewData["Title"] = "Nuevo Pago";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Nuevo Pago</h1>
        <p class="page-subtitle">Registra un nuevo pago en el sistema</p>
    </div>
    <a asp-action="Index" class="btn-fp-ghost">← Volver</a>
</div>

<div style="display:flex;justify-content:center">
    <div class="fp-card accent-crear" style="width:100%;max-width:480px">
        <div class="fp-card-header">
            <span class="fp-card-icon"></span>
            <h2>Datos del pago</h2>
        </div>
        <form asp-action="Crear" method="post">
            @Html.AntiForgeryToken()
            <div class="fp-form-body">
                <div>
                    <label class="fp-form-label">Monto</label>
                    <div class="fp-input-wrap">
                        <span class="fp-input-prefix">S/.</span>
                        <input asp-for="Monto" class="fp-control" type="number" step="0.01" min="0.01" placeholder="0.00" />
                    </div>
                    <span asp-validation-for="Monto" class="fp-field-error"></span>
                </div>
                <div>
                    <label class="fp-form-label">Estado</label>
                    <div class="fp-estado-grid">
                        <div class="fp-estado-opt pendiente">
                            <input type="radio" asp-for="Estado" value="Pendiente" id="est-pend" checked />
                            <label for="est-pend">Pendiente</label>
                        </div>
                        <div class="fp-estado-opt aprobado">
                            <input type="radio" asp-for="Estado" value="Aprobado" id="est-apro" />
                            <label for="est-apro">Aprobado</label>
                        </div>
                    </div>
                    <span asp-validation-for="Estado" class="fp-field-error"></span>
                </div>
            </div>
            <div class="fp-form-actions">
                <a asp-action="Index" class="btn-fp-ghost">Cancelar</a>
                <button type="submit" class="btn-fp-primary"> Guardar pago</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
